{
  "name": "url-to-md",
  "version": "1.0.0",
  "module": "mod.ts",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./mod.ts"
  },
  "bin": {
    "url-to-md": "./index.ts"
  },
  "scripts": {
    "start": "bun run index.ts",
    "build": "mkdir -p ~/.local/bin && bun build --compile --outfile ~/.local/bin/mdurl ./index.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/turndown": "^5.0.6"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "turndown": "^7.2.2"
  }
}
